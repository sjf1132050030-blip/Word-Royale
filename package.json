{
  "name": "word-royale",
  "private": true,
  "version": "1.0.0",
  "description": "Competitive gamified English learning — first closed loop",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:server": "npm run dev -w word-royale-server",
    "dev:client": "npm run dev -w word-royale-client",
    "build:client": "npm run build -w word-royale-client",
    "start": "npm run start -w word-royale-server",
    "start:server": "npm run start -w word-royale-server",
    "seed": "npm run seed -w word-royale-server",
    "e2e": "node server/scripts/e2e-loop.js"
  }
}
